<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Background" Value="{StaticResource PageBackgroundBrush}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Sand}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource Muted}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource WarmWhite}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource Muted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource MistBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="MinimumWidthRequest" Value="48" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

    <Style TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Muted}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Coral}" />
    </Style>

    <Style x:Key="EyebrowLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="EyebrowDarkLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="1.1" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="TextColor" Value="{StaticResource DeepTeal}" />
    </Style>

    <Style x:Key="HeroTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="BannerTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="HeroBodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="SectionTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="SubsectionTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="CardTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.35" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="BodyMutedLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.35" />
        <Setter Property="TextColor" Value="{StaticResource Muted}" />
    </Style>

    <Style x:Key="BulletTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style x:Key="WarningLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Warning}" />
    </Style>

    <Style x:Key="StatValueLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="StatCaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="#DFF7F5" />
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource Coral}" />
        <Setter Property="TextColor" Value="{StaticResource WarmWhite}" />
    </Style>

    <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource WarmWhite}" />
        <Setter Property="TextColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="BorderColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource WarmWhite}" />
        <Setter Property="TextColor" Value="{StaticResource DeepTeal}" />
        <Setter Property="BorderColor" Value="{StaticResource Mist}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="QuizButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource Card}" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BorderColor" Value="{StaticResource Mist}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>
</ResourceDictionary>
